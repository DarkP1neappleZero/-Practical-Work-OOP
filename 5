def run_game():
    # Создаём охотника
    hunter = Hunter("Ван Хельсинг")
    
    # Добавляем оружие
    hunter.add_weapon(SilverSword())
    hunter.add_weapon(HolyWater())
    hunter.add_weapon(CrossbowBolt())
    
    # Создаём список монстров
    monsters = [
        Zombie("Зомби"),
        Vampire("Дракула"),
        Ghost("Призрак"),
        Werewolf("Оборотень")
    ]
    
    # Показываем инвентарь
    hunter.show_inventory()
    print()
    
    # Проходим по всем монстрам
    for monster in monsters:
        print(f"\n=== Встретился монстр: {monster.get_name()}! ===")
        print(f"Здоровье монстра: {monster.get_hp()}")
        
        # Бой с текущим монстром
        while monster.is_alive() and hunter.is_alive():
            # Охотник атакует (используем первое оружие, индекс 0)
            print(f"\n--- Раунд ---")
            hunter.attack(0, monster)
            
            # Если монстр ещё жив, он атакует в ответ
            if monster.is_alive():
                monster.attack_hunter(hunter)
                print(f"Охотник получил {monster.get_dmg()} урона! Осталось HP: {hunter.get_hp()}")
        
        # Проверяем результат боя с этим монстром
        if not hunter.is_alive():
            print(f"\n{monster.get_name()} убил охотника!")
            break
        else:
            print(f"\n{monster.get_name()} повержен!")
    
    # Итоговое сообщение
    print("\n" + "="*30)
    if hunter.is_alive():
        print("ПОБЕДА! Охотник уничтожил всех монстров!")
    else:
        print("ПОРАЖЕНИЕ! Охотник пал в бою...")
    print("="*30)


# Запуск игры
run_game()
